PORT=5001

# NEVER commit real credentials. Rotate any key that was ever committed.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority

# AI provider selection: groq | gemini | grok
AI_PROVIDER=groq

# Groq
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (Google Generative Language API)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_VERSION=

# Grok (xAI)
XAI_API_KEY=YOUR_XAI_API_KEY
XAI_MODEL=grok-4.20-reasoning
XAI_API_BASE=https://api.x.ai/v1

# Retries/timeouts (applies to all providers)
AI_MAX_RETRIES=2
AI_TIMEOUT_MS=60000

# Chunking (characters)
AI_CHUNK_SIZE=4000
AI_MIN_CHUNK_SIZE=1000
AI_MAX_CHUNK_SIZE=8000
AI_MAX_CHUNKS=8

# Debug logging
AI_LOG_RAW=false

AUTO_DEBUG=false
GEMINI_DEBUG_MODEL=gemini-1.5-flash
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
